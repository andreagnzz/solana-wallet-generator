# Solana Network Configuration
SOLANA_NETWORK=mainnet
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Custom RPC endpoints (Helius, QuickNode, Alchemy)
CUSTOM_RPC_MAINNET=
CUSTOM_RPC_DEVNET=https://api.devnet.solana.com
CUSTOM_RPC_TESTNET=https://api.testnet.solana.com

# Security Options
AUTO_LOCK_TIMEOUT=30
MAX_BATCH_SIZE=10000

# External APIs (optional)
COINGECKO_API_KEY=
