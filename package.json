{
  "name": "solana-wallet-generator",
  "version": "1.0.0",
  "description": "Professional Solana wallet generator CLI with HD derivation, vanity addresses, batch generation, and more",
  "main": "dist/cli.js",
  "bin": {
    "solana-wallet": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "wallet",
    "generator",
    "hd-wallet",
    "bip39",
    "crypto",
    "cli"
  ],
  "author": "andreagnzz",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^1.3.0",
    "tweetnacl": "^1.0.3",
    "bs58": "^5.0.0",
    "commander": "^12.1.0",
    "chalk": "^4.1.2",
    "boxen": "^5.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "qrcode-terminal": "^0.12.0",
    "fast-csv": "^5.0.2",
    "dotenv": "^16.4.7",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^20.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "@types/inquirer": "^8.2.10",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/bs58": "^4.0.4",
    "ts-node": "^10.9.0"
  }
}
